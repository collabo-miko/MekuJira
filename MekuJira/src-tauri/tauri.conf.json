{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MekuJira",
  "version": "0.2.5",
  "identifier": "com.shikigami.mekujira",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "url": "/popup",
        "title": "MekuJira",
        "width": 380,
        "height": 520,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/collabo-miko/MekuJira/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRkFFMzA2NkI4Nzc1NzMKUldSemRZZHJCdVA2cjhuaGVia1F6bW4zbGRTQ0VzNGxvbjBOUURSa29GS1VXRVd0QUM1eGRKWUMK"
    }
  }
}
