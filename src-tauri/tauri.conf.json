{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JIRA Focus",
  "version": "0.1.0",
  "identifier": "com.shikigami.jira-focus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "url": "/popup",
        "title": "JIRA Focus",
        "width": 380,
        "height": 520,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "widget",
        "url": "/widget",
        "title": "JIRA Focus Widget",
        "width": 300,
        "height": 200,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "http": {
      "scope": {
        "allow": [
          {
            "url": "https://*.atlassian.net/**"
          }
        ]
      }
    }
  }
}
