# OpenAI API Key (required for self-hosted PageIndex)
OPENAI_API_KEY=sk-your-key-here

# PageIndex settings (self-hosted)
PAGEINDEX_MODEL=gpt-4o-2024-11-20
PAGEINDEX_MAX_PAGES_PER_NODE=10
PAGEINDEX_MAX_TOKENS_PER_NODE=20000

# PageIndex Cloud API (optional - set PAGEINDEX_USE_CLOUD=true to use cloud instead of self-hosted)
PAGEINDEX_API_KEY=
PAGEINDEX_USE_CLOUD=false

# Server settings
HOST=0.0.0.0
PORT=8000

# Confidence thresholds
DEFAULT_CONFIDENCE_THRESHOLD=0.70
CONFIDENCE_STRICT=0.95
CONFIDENCE_MODERATE=0.85
CONFIDENCE_STANDARD=0.70

# CORS settings
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
